# MongoDB (local container default)
MONGO_CONNECTION_STRING=mongodb://localhost:27017
COSMOS_DATABASE_NAME=cams-local

# Azurite blob storage — use the standard Azurite local dev connection string.
# See: https://learn.microsoft.com/en-us/azure/storage/common/storage-use-azurite#well-known-storage-account-and-key
# Or run `npm run import-zoom-csv -- check-env` for the exact value to paste here.
AzureWebJobsStorage=<azurite-local-connection-string>

# Blob container name (must exist in the storage account)
CAMS_OBJECT_CONTAINER=migration-files
