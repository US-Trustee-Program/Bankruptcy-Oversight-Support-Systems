# Dataflows function app image for migrate-case-appointments integration tests.
#
# Self-contained — no dependency on e2e images.
# MongoDB, SQL Edge, and Azurite run as pod siblings sharing localhost.
#
# Build from repo root:
#   podman build -t localhost/integration_dataflows:latest \
#     -f test/integration/migrate-case-appointments/Dockerfile.dataflows .

FROM node:22-bookworm-slim

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y curl libicu72 netcat-openbsd && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Azure Functions Core Tools
RUN npm install -g azure-functions-core-tools@4 --unsafe-perm true

# Install workspace deps (cached layer — only busts on package file changes)
# All workspace package.json files must be present for root npm ci to resolve
COPY package*.json ./
COPY common/package*.json ./common/
COPY backend/package*.json ./backend/
COPY user-interface/package*.json ./user-interface/
COPY dev-tools/package*.json ./dev-tools/
COPY test/bdd/package*.json ./test/bdd/
COPY test/e2e/package*.json ./test/e2e/
COPY test/uswds/package*.json ./test/uswds/

RUN npm ci

# Build common and dataflows
COPY common/ ./common/
COPY backend/ ./backend/

RUN npm run build:dataflows

# Pre-cache Azure Functions extension bundles
WORKDIR /app/backend/function-apps/dataflows
RUN func bundles download

# Bake in integration settings — no host file swapping needed
COPY test/integration/migrate-case-appointments/local.settings.integration.json ./local.settings.json

COPY test/integration/migrate-case-appointments/scripts/entrypoint-dataflows.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 7072

CMD ["/app/entrypoint.sh"]
