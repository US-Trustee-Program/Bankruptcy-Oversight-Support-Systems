{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "types": ["vite/client", "node"],

    /* Path mapping */
    // TODO: baseUrl is deprecated in TS 7.0. Migrate path aliases away from baseUrl before upgrading TypeScript.
    // ignoreDeprecations silences TS5101 without removing the functionality we still need.
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../user-interface/src/*"],
      "@common/*": ["../../common/src/*"],
      "react": ["../../user-interface/node_modules/@types/react/index.d.ts"],
      "react/*": ["../../user-interface/node_modules/@types/react/*"]
    },
    "typeRoots": ["../../user-interface/node_modules/@types", "../../node_modules/@types"]
  },
  "include": ["src"]
}
