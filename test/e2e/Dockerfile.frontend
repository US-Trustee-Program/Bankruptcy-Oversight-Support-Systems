# Frontend UI Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/user-interface

EXPOSE 3000

# Generate configuration.json from environment variables at startup, copy to build dir, then start server
CMD ["sh", "-c", "npm run envToConfig && cp public/configuration.json build/configuration.json && npx vite preview --port 3000 --strict-port --host 0.0.0.0"]
