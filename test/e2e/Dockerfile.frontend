# Frontend UI Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/user-interface

# Overwrite the default vite config with the E2E proxy config so that /api
# requests are forwarded to the backend container via bridge DNS, eliminating
# cross-origin requests and the Azure Functions OPTIONS preflight rejection.
COPY test/e2e/vite.config.e2e.mts /app/user-interface/vite.config.mts

EXPOSE 3000

CMD ["sh", "-c", "node envToConfig.js && cp public/configuration.json build/configuration.json && npx vite preview --port 3000 --strict-port --host 0.0.0.0"]
