{
  "name": "e2e",
  "version": "1.0.0",
  "description": "",
  "main": "playwright.config.ts",
  "scripts": {
    "clean": "rm -rf node_modules & rm -rf test-results & rm -rf playwright-report",
    "headless": "PW_TEST_HTML_REPORT_OPEN=never playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed": "tsx ./scripts/seed-database.ts",
    "seed:sql": "tsx ./scripts/seed-sqlserver.ts",
    "seed:all": "npm run seed && npm run seed:sql",
    "harvest": "./scripts/harvest-fixtures.sh",
    "harvest:reseed": "./scripts/harvest-fixtures.sh --reseed",
    "extract:case-ids": "tsx ./scripts/extract-case-ids.ts",
    "load-data": "tsx --env-file=.env ./scripts/load-cosmos-data.ts",
    "load-data:ci": "tsx ./scripts/load-cosmos-data.ts",
    "typecheck": "npx tsc --noEmit",
    "ui": "playwright test --ui",
    "test": "playwright test",
    "e2e": "./scripts/run-e2e-workflow.sh",
    "e2e:open": "./scripts/run-e2e-workflow.sh --open-report",
    "podman:cache-images": "./scripts/cache-base-images.sh",
    "podman:install": "./scripts/install-podman.sh",
    "podman:prereqs": "podman build -t localhost/e2e_deps:latest -f Dockerfile.deps ../../ && podman build -t localhost/e2e_built:latest -f Dockerfile.built ../../",
    "podman:rebuild-deps": "podman build --no-cache -t localhost/e2e_deps:latest -f Dockerfile.deps ../../",
    "podman:rebuild-built": "podman build --no-cache -t localhost/e2e_built:latest -f Dockerfile.built ../../",
    "podman:test": "npm run podman:prereqs && podman-compose up --build --abort-on-container-exit && podman-compose down",
    "podman:services": "npm run podman:prereqs && podman-compose up --build -d backend frontend",
    "podman:debug": "npm run podman:prereqs && podman-compose up --build backend frontend",
    "podman:logs": "podman-compose logs -f",
    "podman:status": "podman-compose ps",
    "podman:down": "podman-compose down",
    "podman:clean": "podman-compose down -v --rmi local && rm -rf test-results playwright-report",
    "podman:rebuild": "npm run podman:rebuild-built && podman-compose build --no-cache",
    "report": "playwright show-report"
  },
  "author": "",
  "license": "CC0 v1.0",
  "devDependencies": {
    "@eslint/js": "10.0.0",
    "@playwright/test": "1.60.0",
    "@types/node": "24.13.1",
    "dotenv": "17.4.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "dependencies": {
    "@azure/functions": "4.16.0",
    "@faker-js/faker": "9.9.0",
    "mongodb": "7.3.0",
    "mssql": "12.5.5",
    "ts-node": "10.9.2",
    "tsx": "4.22.4"
  }
}
