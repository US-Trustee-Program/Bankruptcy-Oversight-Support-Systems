# Backend API Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/backend/function-apps/api

# Install Azurite locally so the Functions runtime can use UseDevelopmentStorage=true
# (which requires 127.0.0.1). Running Azurite in-process avoids all bridge-network
# SharedKey HMAC incompatibilities and startup race conditions.
RUN npm install -g azurite

# Provide CORS config for the local Functions host — the Azure platform handles CORS
# in production via Bicep, but in the containerized E2E environment we need this file.
COPY test/e2e/local.settings.backend.json ./local.settings.json

EXPOSE 7071

# Start Azurite in the background then launch the Functions host.
# Azurite binds to 127.0.0.1 by default, satisfying UseDevelopmentStorage=true.
CMD ["sh", "-c", "azurite --silent --location /tmp/azurite & func start --javascript --port 7071 --host 0.0.0.0"]
