# Backend API Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/backend/function-apps/api

EXPOSE 7071

# Start Azurite in the background, wait until all three services are ready,
# then launch the Functions host. Azurite binds to 127.0.0.1 by default.
# Log to file so we can poll for readiness.
CMD ["sh", "-c", "azurite --location /tmp/azurite > /tmp/azurite.log 2>&1 & until grep -q 'Table service is successfully listening' /tmp/azurite.log 2>/dev/null; do sleep 0.1; done && func start --javascript --port 7071 --host 0.0.0.0"]
