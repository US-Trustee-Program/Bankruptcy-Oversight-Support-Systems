# Backend API Dockerfile for E2E Testing
#
# Single container running all E2E services on localhost:
# - MongoDB (port 27017), SQL Edge (port 1433), Azurite (ports 10000-10002)
# - Azure Functions host (port 7071)
#
# MongoDB, SQL Edge, Azurite, and supervisord are pre-installed in e2e_deps.
# This image just adds config files and the entrypoint.
FROM localhost/e2e_built:latest

# Provide CORS config and host settings for the local Functions host
WORKDIR /app/backend/function-apps/api
COPY test/e2e/local.settings.backend.json ./local.settings.json
COPY test/e2e/host.backend.json ./host.json

WORKDIR /app

# Copy e2e seed scripts and fixtures (not in e2e_built which only has common/backend/ui)
COPY test/e2e/scripts/ ./test/e2e/scripts/
COPY test/e2e/fixtures/ ./test/e2e/fixtures/
COPY test/e2e/package.json ./test/e2e/package.json

# Copy entrypoint
COPY test/e2e/scripts/entrypoint-backend.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 7071 27017 1433 10000 10001 10002

CMD ["/app/entrypoint.sh"]
