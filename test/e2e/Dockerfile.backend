# Backend API Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/backend/function-apps/api

# Provide CORS config for the local Functions host — the Azure platform handles CORS
# in production via Bicep, but in the containerized E2E environment we need this file.
COPY test/e2e/local.settings.backend.json ./local.settings.json

EXPOSE 7071

# Start Azurite in the background, wait for all three services (blob/queue/table)
# to be socket-ready on localhost, then launch the Functions host.
# TCP port checks are more reliable than log grepping for race condition prevention.
CMD ["sh", "-c", "azurite --location /tmp/azurite --silent > /tmp/azurite.log 2>&1 & echo 'Waiting for Azurite services...' && until nc -z localhost 10000 && nc -z localhost 10001 && nc -z localhost 10002; do sleep 0.5; done && echo 'Azurite ready!' && func start --javascript --port 7071 --host 0.0.0.0"]
