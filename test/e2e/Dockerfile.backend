# Backend API Dockerfile for E2E Testing
FROM localhost/e2e_built:latest

WORKDIR /app/backend/function-apps/api

# Provide CORS config for the local Functions host — the Azure platform handles CORS
# in production via Bicep, but in the containerized E2E environment we need this file.
COPY test/e2e/local.settings.backend.json ./local.settings.json

EXPOSE 7071

# Start Azurite in the background, wait for all three services to be HTTP-ready,
# then launch the Functions host. HTTP checks ensure Azurite is fully initialized
# and can handle storage requests, preventing IServiceProvider disposal errors.
CMD ["sh", "-c", "azurite --location /tmp/azurite --silent > /tmp/azurite.log 2>&1 & echo 'Waiting for embedded Azurite on 127.0.0.1:10000...' && timeout 60s bash -c 'until curl -s --connect-timeout 2 http://127.0.0.1:10000/ > /dev/null 2>&1; do echo \"Azurite not ready...\"; sleep 2; done' && echo 'Azurite is responding!' && sleep 5 && func start --javascript --port 7071 --host 0.0.0.0"]
