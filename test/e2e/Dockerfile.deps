# Dependencies-only base image (cached, rarely changes)
FROM node:22-bookworm-slim

WORKDIR /app

# Install system dependencies once (cached layer)
# netcat-openbsd needed for TCP port checks in backend startup
RUN apt-get update && \
    apt-get install -y curl libicu72 netcat-openbsd && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install Azure Functions Core Tools and Azurite globally together so
# both tools share a consistent global node_modules dependency resolution.
# Installing azurite here (rather than in Dockerfile.backend) avoids npm
# restructuring the global node_modules after the runtime is installed.
RUN npm install -g azure-functions-core-tools@4 azurite --unsafe-perm true

# Copy only package files for dependency installation (cached layer)
COPY package*.json ./
COPY common/package*.json ./common/
COPY backend/package*.json ./backend/
COPY user-interface/package*.json ./user-interface/
COPY test/e2e/package*.json ./test/e2e/

# Install all dependencies (cached layer - only rebuilds when package*.json changes)
RUN npm ci
