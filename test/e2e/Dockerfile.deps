# Dependencies-only base image (cached, rarely changes)
#
# Includes: Node.js deps, Azure Functions Core Tools, Azurite,
# MongoDB server, Azure SQL Edge, and supervisord.

# Grab binaries from official images
FROM mcr.microsoft.com/azure-sql-edge:latest AS sqledge
FROM mongo:7.0 AS mongodb

# Build the deps image
FROM node:22-bookworm-slim

WORKDIR /app

# Install system dependencies, supervisor, and runtime libs for MongoDB + SQL Edge
RUN apt-get update && \
    apt-get install -y curl libicu72 netcat-openbsd libssl3 libcurl4 libnuma1 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install Azure Functions Core Tools and Azurite globally together so
# both tools share a consistent global node_modules dependency resolution.
RUN npm install -g azure-functions-core-tools@4 azurite --unsafe-perm true

# Copy MongoDB binaries from official image (ARM64 native)
COPY --from=mongodb /usr/bin/mongod /usr/bin/mongod
COPY --from=mongodb /usr/bin/mongosh /usr/bin/mongosh
COPY --from=mongodb /usr/bin/mongos /usr/bin/mongos

# Copy SQL Edge binaries and ALL shared libraries from official image.
# SQL Edge links against OpenSSL 1.1, libldap 2.4, Heimdal Kerberos, and
# libsss-nss-idmap — none of which are in Bookworm. Rather than chasing
# individual .so files, copy the entire lib directory into a separate path
# and use LD_LIBRARY_PATH so sqlservr finds them without conflicting with
# the host's libs. This is arch-agnostic (works on both aarch64 and x86_64).
COPY --from=sqledge /opt/mssql /opt/mssql
# Copy all shared libraries from SQL Edge into a dedicated path.
# SQL Edge depends on OpenSSL 1.1, libldap 2.4, Heimdal Kerberos, etc.
# which don't exist in Bookworm. Copying the whole arch-specific lib dir
# and adding it to the linker path avoids chasing individual .so files.
# The wildcard handles both aarch64-linux-gnu (ARM64) and x86_64-linux-gnu (amd64).
COPY --from=sqledge /usr/lib/ /opt/mssql-libs/usr/lib/
RUN find /opt/mssql-libs -type d -name "*linux-gnu*" | head -1 | xargs -I{} ln -sf {} /opt/mssql-libs/native && \
    ldconfig /opt/mssql-libs/native
ENV PATH="/opt/mssql/bin:${PATH}"

# Create data/log directories for all embedded services
RUN mkdir -p /data/db /var/log/mongodb /var/log/supervisor \
    /var/opt/mssql/data /var/opt/mssql/log /var/opt/mssql/secrets \
    /data/azurite && \
    chmod -R 777 /data/db /var/log/mongodb /var/opt/mssql /data/azurite

# Copy only package files for dependency installation (cached layer)
COPY package*.json ./
COPY common/package*.json ./common/
COPY backend/package*.json ./backend/
COPY user-interface/package*.json ./user-interface/
COPY test/e2e/package*.json ./test/e2e/

# Install all dependencies (cached layer - only rebuilds when package*.json changes)
RUN npm ci
