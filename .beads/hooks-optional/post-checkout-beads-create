#!/usr/bin/env bash
# Post-checkout hook to auto-create/claim beads issues for CAMS-* branches
# Install: Add to .git/hooks/post-checkout or call from existing hook

# Arguments: previous-HEAD new-HEAD branch-checkout-flag
_prev_head=$1
_new_head=$2
branch_checkout=$3

# Only run on branch checkouts (not file checkouts)
if [ "$branch_checkout" != "1" ]; then
    exit 0
fi

# Get current branch name
branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Check if branch matches CAMS-XXX pattern
if [[ ! $branch =~ ^CAMS-([0-9]+) ]]; then
    exit 0
fi

ticket="CAMS-${BASH_REMATCH[1]}"
echo "📋 Branch $branch detected, checking beads..."

# Check if beads issue already exists
beads_issue=$(bd list --json 2>/dev/null | jq -r ".[] | select(.title | contains(\"$ticket\")) | .id" | head -1)

if [ -n "$beads_issue" ]; then
    # Issue exists - check if it's already claimed
    assignee=$(bd show "$beads_issue" --json 2>/dev/null | jq -r '.assignee // empty')
    status=$(bd show "$beads_issue" --json 2>/dev/null | jq -r '.status')

    if [ -z "$assignee" ] || [ "$status" = "open" ]; then
        echo "   Claiming existing issue $beads_issue..."
        bd update "$beads_issue" --claim --quiet 2>/dev/null || true
        echo "   ✓ Issue $beads_issue claimed and set to in_progress"
    else
        echo "   ✓ Issue $beads_issue already claimed by $assignee"
    fi
else
    # Issue doesn't exist - try to create from GitHub
    echo "   No beads issue found, checking GitHub..."

    # Search for GitHub issue with this label
    gh_data=$(gh issue list --label "$ticket" --json number,title,labels --limit 1 2>/dev/null)

    if [ -n "$gh_data" ] && [ "$gh_data" != "[]" ]; then
        # Extract GitHub issue details
        gh_number=$(echo "$gh_data" | jq -r '.[0].number')
        gh_title=$(echo "$gh_data" | jq -r '.[0].title')
        gh_labels=$(echo "$gh_data" | jq -r '.[0].labels[].name')

        # Determine type from labels
        type="task"
        if echo "$gh_labels" | grep -q "bug"; then
            type="bug"
        elif echo "$gh_labels" | grep -qE "(enhancement|user_story)"; then
            type="feature"
        fi

        echo "   Creating beads issue from GitHub #$gh_number..."

        new_issue=$(bd create \
            --title="$ticket: $gh_title" \
            --description="Auto-created from GitHub issue #$gh_number on branch checkout. See GitHub for full requirements." \
            --external-ref="gh-$gh_number" \
            --type="$type" \
            --priority=2 \
            --silent 2>/dev/null)

        if [ -n "$new_issue" ]; then
            echo "   ✓ Created beads issue $new_issue"
            echo "   Claiming issue..."
            bd update "$new_issue" --claim --quiet 2>/dev/null || true
            echo "   ✓ Issue claimed and ready to work"
        fi
    else
        echo "   ⚠️  No GitHub issue found with label $ticket"
        echo "   💡 Create manually: bd create --title=\"$ticket: Description\""
    fi
fi

exit 0
