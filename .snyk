# Snyk policy file — SCA license finding ignores
# https://docs.snyk.io/snyk-cli/commands/policy
version: v1.25.0
ignore:
  'snyk:lic:npm:rasha:MPL-2.0':
    - '*':
        reason: >-
          Transitive dependency of @okta/okta-sdk-nodejs. MPL-2.0 is weak
          copyleft compatible with project use. Package is unmodified.
  'snyk:lic:npm:eckles:MPL-2.0':
    - '*':
        reason: >-
          Transitive dependency of @okta/okta-sdk-nodejs. MPL-2.0 is weak
          copyleft compatible with project use. Package is unmodified.
  SNYK-JS-JSONBIGINT-6148131:
    - '*':
        reason: 'False positive - json-bigint not in package-lock.json or dependency tree'
        expires: 2026-05-06T00:00:00.000Z
  SNYK-JS-XML2JS-5414874:
    - '*':
        reason: 'False positive - xml2js not in package-lock.json or dependency tree'
        expires: 2026-05-06T00:00:00.000Z
  SNYK-JS-DOMPURIFY-15371376:
    - '*':
        reason: 'Mitigated by design - we block the elements that DOMPurify handles poorly'
        expires: 2026-06-06T00:00:00.000Z
  SNYK-JS-LODASH-15869619:
    - '*':
        reason: >-
          Mitigated by design - lodash replaced entirely with a native JS shim
          (shim/lodash-shim) containing no lodash source code. The vulnerability
          does not exist in this codebase.
  SNYK-JS-LODASH-15869625:
    - '*':
        reason: >-
          Mitigated by design - lodash replaced entirely with a native JS shim
          (shim/lodash-shim) containing no lodash source code. The vulnerability
          does not exist in this codebase.
