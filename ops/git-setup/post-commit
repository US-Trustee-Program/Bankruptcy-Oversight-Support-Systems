#!/bin/bash
# Post-commit hook - updates QMD index after committing changes
# Installed by ops/git-setup/set-up-git-hooks.sh

# Check if qmd is installed
if ! command -v qmd &> /dev/null; then
    exit 0
fi

# Run update in background with all output suppressed
qmd update cams &>/dev/null &

exit 0
