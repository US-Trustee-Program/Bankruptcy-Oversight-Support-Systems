    {
      "type": 1,
      "content": {
        "json": "## Active Usage Over Time\nNumber of trustee notes created per week/month"
      },
      "name": "text - 5"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "customEvents\n| where customDimensions.moduleName == \"SYNC-TRUSTEE-NOTES-METRICS\"\n| where name == \"DataflowHandlerComplete\"\n| where timestamp {TimeRange}\n| extend \n    notesCount = todouble(customDimensions.notesLast24Hrs),\n    invocationId = tostring(customDimensions.invocationId)\n| summarize MaxNotesPerInvocation = max(notesCount) by invocationId, bin(timestamp, 1d)\n| summarize TotalNotesCreated = sum(MaxNotesPerInvocation) by Day = startofday(timestamp)\n| order by Day asc\n",
        "size": 0,
        "timeContextFromParameter": "TimeRange",
        "queryType": 0,
        "resourceType": "microsoft.insights/components",
        "visualization": "linechart",
        "sortBy": [],
        "chartSettings": {
          "xAxis": "Day",
          "showMetrics": false,
          "showDataPoints": true,
          "xSettings": {
            "numberFormatSettings": {
              "unit": 27,
              "options": {
                "style": "decimal",
                "useGrouping": true
              }
            }
          }
        }
      },
      "name": "overall-note-count"
    },
    {
      "type": 1,
      "content": {
        "json": "## Adoption Rate Over Time\nPercentage of trustees that have at least one note in the system"
      },
      "name": "text - 6"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "customEvents\n| where customDimensions.moduleName == \"SYNC-TRUSTEE-NOTES-METRICS\"\n| where name == \"DataflowHandlerComplete\"\n| where timestamp {TimeRange}\n| extend Percentage = todouble(customDimensions.trusteesWithNotesPercent)\n| summarize LatestPercentage = max(Percentage) by Day = startofday(timestamp)\n| order by Day asc",
        "size": 0,
        "timeContext": {
          "durationMs": 86400000
        },
        "queryType": 0,
        "resourceType": "microsoft.insights/components",
        "visualization": "linechart",
        "tileSettings": {
          "showBorder": false
        },
        "chartSettings": {
          "showMetrics": false,
          "showDataPoints": true
        }
      },
      "name": "percent-trustees-with-one-note"
    },
    {
      "type": 1,
      "content": {
        "json": "## User Engagement Over Time\nPercentage of users with trustee oversight responsibilities who create trustee notes"
      },
      "name": "text - 7"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "customEvents\n| where customDimensions.moduleName == \"SYNC-TRUSTEE-NOTES-METRICS\"\n| where name == \"DataflowHandlerComplete\"\n| where timestamp {TimeRange}\n| extend Engagement = todouble(customDimensions.userEngagementPercent)\n| summarize LatestEngagement = max(Engagement) by Day = startofday(timestamp)\n| order by Day asc",
        "size": 0,
        "timeContext": {
          "durationMs": 86400000
        },
        "queryType": 0,
        "resourceType": "microsoft.insights/components",
        "visualization": "linechart",
        "chartSettings": {
          "showMetrics": false,
          "showDataPoints": true
        }
      },
      "name": "user-engagement"
    }
