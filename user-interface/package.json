{
  "name": "cams",
  "version": "0.1.0",
  "private": true,
  "license": "CC0 v1.0",
  "description": "Bankruptcy Oversight Support System - Graphical Frontend User Interface",
  "scripts": {
    "build": "npm run envToConfig && tsc --noEmit && vite build",
    "build-common": "pushd ../common && npm ci && npm run build && popd",
    "clean": "rm -rf build && rm -rf node_modules && rm -rf ./coverage",
    "coverage": "export CAMS_USE_FAKE_API=true && vitest run --coverage",
    "coverage:ci": "export CAMS_USE_FAKE_API=true && vitest run --coverage",
    "dependency-cruiser-graphical": "current_time=$(date +'%Y-%m-%d_%H%M') && npx depcruise --output-type dot --do-not-follow '^node_modules($|/)' public src | dot -T svg > ../docs/architecture/dependency-cruiser/user-interface/dependency-graph_${current_time}.svg",
    "dependency-cruiser:ci": "npx depcruise --output-type err-long public src",
    "envToConfig": "node ./envToConfig.js",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "serve": "npm run envToConfig && npm run build && vite preview --port 3000 --strict-port",
    "slotConfig": "node ./envToConfig.js -f configuration-${SLOT_NAME:-staging}.json",
    "start": "npm run envToConfig && vite",
    "start:utm": "npm run envToConfig && vite --host 0.0.0.0 --port 3000 --strict-port",
    "start:a11y": "export CAMS_USE_FAKE_API=true && export CAMS_LOGIN_PROVIDER=none && npm run envToConfig && tsc --noEmit && vite build && vite preview --port 3000 --strict-port",
    "test": "export CAMS_USE_FAKE_API=true && vitest run",
    "test:a11y": "playwright test --reporter=list,html",
    "test:a11y:clean": "rm -rf test-results & rm -rf playwright-report",
    "test:a11y:ui": "playwright test --ui",
    "test:screen-reader": "export CAMS_USE_FAKE_API=true && export CAMS_LOGIN_PROVIDER=none && npm run envToConfig && vite --host 0.0.0.0 --port 3000 --strict-port",
    "test:watch": "export CAMS_USE_FAKE_API=true && vitest watch",
    "typecheck": "tsc -b --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": []
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@microsoft/applicationinsights-react-js": "19.4.0",
    "@microsoft/applicationinsights-web": "3.4.1",
    "@okta/okta-auth-js": "8.0.1",
    "@okta/okta-react": "6.11.0",
    "@tiptap/core": "3.25.0",
    "@tiptap/extension-bold": "3.25.0",
    "@tiptap/extension-document": "3.25.0",
    "@tiptap/extension-italic": "3.25.0",
    "@tiptap/extension-list": "3.25.0",
    "@tiptap/extension-paragraph": "3.25.0",
    "@tiptap/extension-text": "3.25.0",
    "@tiptap/extension-underline": "3.25.0",
    "@tiptap/extensions": "3.25.0",
    "@tiptap/pm": "3.25.0",
    "@tiptap/react": "3.25.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "24.13.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@uswds/uswds": "3.13.0",
    "dompurify": "3.4.11",
    "dotenv": "17.4.2",
    "launchdarkly-react-client-sdk": "3.9.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.16.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint-react/eslint-plugin": "5.8.11",
    "@eslint/js": "10.0.0",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.19",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "17.4.3",
    "esbuild": "0.28.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-testing-library": "7.16.2",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "react-router": "7.16.0",
    "sass": "1.100.0",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vite-plugin-env-compatible": "2.0.1",
    "vite-plugin-static-copy": "4.1.0",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}
