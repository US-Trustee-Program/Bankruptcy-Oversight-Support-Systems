{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "playwright": false,
  "rules": {
    "enumMembers": "off"
  },
  "workspaces": {
    ".": {
      "ignore": []
    },
    "backend": {
      "entry": [
        "function-apps/**/*.function.ts",
        "function-apps/dataflows/dataflows.ts",
        "**/*.test.ts"
      ],
      "project": ["**/*.ts"],
      "ignore": [],
      "ignoreFiles": [
        "function-apps/api/index.ts",
        "lib/testing/mock-gateways/mock-oauth2-constants.ts"
      ]
    },
    "user-interface": {
      "entry": [
        "test/**/*.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts", "!playwright.config.ts"],
      "ignore": []
    },
    "common": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignore": []
    },
    "test/bdd": {
      "entry": [
        "features/**/*.spec.tsx",
        "helpers/**/*.ts",
        "helpers/**/*.tsx",
        "fixtures/**/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignore": []
    },
    "test/e2e": {
      "entry": ["**/*.ts"],
      "project": ["**/*.ts"],
      "ignore": []
    },
    "dev-tools": {
      "entry": ["**/*.ts"],
      "project": ["**/*.ts"],
      "ignore": []
    },
    "downstream": {
      "entry": [
        "functions/**/index.ts",
        "**/*.test.ts"
      ],
      "project": ["**/*.ts"],
      "ignore": [],
      "ignoreFiles": []
    }
  },
  "ignoreBinaries": [
    "pushd",
    "popd",
    "playwright",
    "dot",
    "dev-tools/.venv-docs/bin/python",
    "dev-tools/.venv-docs/bin/python3",
    "python3"
  ],
  "ignoreDependencies": [
    "@azure/cosmos",
    "@azure/identity",
    "@azure/keyvault-secrets",
    "@uswds/uswds",
    "buffer",
    "ts-node",
    "@eslint/js",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "eslint-config-prettier",
    "eslint-plugin-import",
    "eslint-plugin-jsx-a11y",
    "eslint-plugin-n",
    "eslint-plugin-prettier",
    "eslint-plugin-promise",
    "eslint-plugin-react",
    "eslint-plugin-react-hooks",
    "eslint-plugin-testing-library",
    "@vitest/eslint-plugin",
    "prettier",
    "typescript-eslint",
    "cams",
    "esbuild",
    "@launchdarkly/node-server-sdk",
    "launchdarkly-react-client-sdk",
    "@okta/okta-auth-js",
    "@launchdarkly/node-server-sdk",
    "launchdarkly-react-client-sdk",
    "react-router-dom",
    "common",
    "@common/cams",
    "globals"
  ]
}
