{
  "name": "dev-tools",
  "version": "1.0.0",
  "license": "CC0 v1.0",
  "description": "Custom tools used to aid development.",
  "type": "module",
  "scripts": {
    "generate-api-key": "tsx --env-file=.env-dev-local api-keys/generate-key.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed:local": "tsx --env-file=.env-dev-local runner.ts",
    "seed:main": "tsx --env-file=.env-dev-main runner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npx tsc --noEmit",
    "unseed:local": "tsx --env-file=.env-dev-local unseed.ts",
    "unseed:main": "tsx --env-file=.env-dev-main unseed.ts"
  },
  "author": "",
  "dependencies": {
    "@azure/cosmos": "4.9.3",
    "@azure/identity": "4.13.1",
    "@faker-js/faker": "9.9.0",
    "@types/node": "24.12.4",
    "mongodb": "7.2.0",
    "mssql": "12.5.5",
    "tsx": "4.22.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.0",
    "@types/mssql": "12.3.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
