{
  "compilerOptions": {
    "target": "ES2015",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["es6"],
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "ts-node": {
    "esm": true
  },
  "references": [{ "path": "../common" }],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "eslint.config.mjs"
  ],
}
