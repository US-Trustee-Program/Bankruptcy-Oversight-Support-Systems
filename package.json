{
  "name": "cams",
  "version": "0.1.0",
  "private": true,
  "license": "CC0 v1.0",
  "description": "Bankruptcy Oversight Support System - Parent Project",
  "workspaces": [
    "common",
    "backend",
    "user-interface",
    "dev-tools",
    "test/bdd",
    "test/e2e",
    "test/uswds"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:user-interface",
    "build:api": "npm run build:common && npm run build:api --workspace=backend",
    "build:backend": "npm run build:common && npm run build --workspace=backend",
    "build:common": "npm run build --workspace=common",
    "build:dataflows": "npm run build:common && npm run build:dataflows --workspace=backend",
    "build:user-interface": "npm run build:common && npm run build --workspace=user-interface",
    "clean": "rm -rf node_modules && npm run clean --workspaces --if-present",
    "clean-and-build": "npm run clean && npm ci && npm run build",
    "coverage:backend": "npm run coverage --workspace=backend",
    "coverage:bdd": "npm run coverage --workspace=test/bdd",
    "coverage:common": "npm run coverage --workspace=common",
    "coverage:user-interface": "npm run coverage --workspace=user-interface",
    "docs:install-tools": "sh ./ops/install-docs-tools.sh",
    "docs:regen": "sh ./architecture/export-architecture-diagrams.sh && ( [ -x dev-tools/.venv-docs/bin/python3 ] && dev-tools/.venv-docs/bin/python3 ops/scripts/pipeline/workflow-diagram-generator.py || ( [ -x dev-tools/.venv-docs/bin/python ] && dev-tools/.venv-docs/bin/python ops/scripts/pipeline/workflow-diagram-generator.py ) || python3 ops/scripts/pipeline/workflow-diagram-generator.py ) && git add docs/",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint": "npm run lint --workspaces --if-present -- --quiet",
    "lint:fix": "npm run lint:fix --workspaces --if-present -- --quiet",
    "lint:ops": "eslint ops/",
    "lint:validate": "node dev-tools/validate-eslint-rules.mjs",
    "start:backend": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=user-interface",
    "start:uswds": "npm run dev --workspace=test/uswds",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test --workspace=backend",
    "test:bdd": "npm run test --workspace=test/bdd",
    "test:bdd:show-logs": "npm run test:show-logs --workspace=test/bdd",
    "test:bdd:watch": "npm run test:watch --workspace=test/bdd",
    "test:common": "npm run test --workspace=common",
    "test:e2e": "npm run e2e --workspace=test/e2e",
    "test:user-interface": "npm run test --workspace=user-interface",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:watch:backend": "npm run test:watch --workspace=backend",
    "test:watch:common": "npm run test:watch --workspace=common",
    "test:watch:user-interface": "npm run test:watch --workspace=user-interface",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@azure/storage-blob": "12.33.0",
    "@azure/storage-queue": "12.31.0",
    "@eslint-react/eslint-plugin": "5.13.2",
    "@eslint/js": "10.0.0",
    "@types/node": "24.13.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitest/eslint-plugin": "1.6.23",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-testing-library": "7.16.2",
    "knip": "6.26.0",
    "mongodb": "7.5.0",
    "mssql": "12.7.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "form-data": "4.0.6",
    "body-parser": "2.3.0",
    "js-yaml": "4.3.0",
    "semver": "7.8.4",
    "@babel/runtime": "7.29.7",
    "node-forge": "1.4.0",
    "path-to-regexp": "8.4.2",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-prometheus": "0.218.0",
    "qs": "6.15.2",
    "uuid": "11.1.1",
    "@okta/okta-sdk-nodejs": {
      "lodash": "4.18.1"
    },
    "@opentelemetry/propagator-jaeger": "2.9.0",
    "protobufjs": "7.6.5",
    "undici": "7.28.0"
  }
}
