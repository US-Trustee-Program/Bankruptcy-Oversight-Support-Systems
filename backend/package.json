{
  "name": "node",
  "version": "1.0.0",
  "license": "CC0 v1.0",
  "description": "",
  "workspaces": [
    "function-apps/api",
    "function-apps/dataflows"
  ],
  "scripts": {
    "all": "npm run clean:all && npm ci && npm run build:all && npm run pack:all",
    "build": "npm run build:all",
    "build:all": "npm run build:api && npm run build:dataflows",
    "build:api": "(cd function-apps/api && npm run build)",
    "build:dataflows": "(cd function-apps/dataflows && npm run build)",
    "clean": "rm -rf ./dist && rm -rf ./coverage",
    "clean:all": "npm run clean && npm run clean:api && npm run clean:dataflows",
    "clean:api": "(cd function-apps/api && npm run clean)",
    "clean:dataflows": "(cd function-apps/dataflows && npm run clean)",
    "coverage": "npm test -- --coverage",
    "coverage:ci": "npm test -- --coverage",
    "dependency-cruiser-graphical": "current_time=$(date +'%Y-%m-%d_%H%M') && npx depcruise --output-type dot --do-not-follow '^node_modules($|/)' function-apps/api/staff case-assignments case-docket case-history case-summary cases consolidations healthcheck offices orders orders-manual-sync orders-sync ../lib | dot -T svg > ../../docs/architecture/dependency-cruiser/functions/dependency-graph_api_${current_time}.svg",
    "dependency-cruiser:ci": "npx depcruise --output-type err-long function-apps/api/staff case-assignments case-docket case-history case-summary cases consolidations healthcheck offices orders orders-manual-sync orders-sync ../lib ",
    "format": "prettier --write './**/*.{js,ts,css,md,json}' --config .prettierrc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack": "npm run pack:api",
    "pack:all": "npm run pack:api && npm run pack:dataflows",
    "pack:api": "(cd function-apps/api && npm run pack)",
    "pack:dataflows": "(cd function-apps/dataflows && npm run pack)",
    "start": "npm run start:api",
    "start:api": "(cd function-apps/api && npm run start)",
    "start:dataflows": "(cd function-apps/dataflows && npm run start)",
    "start:express": "tsx --watch express/server.ts",
    "test": "CAMS_LOGIN_PROVIDER='mock' DATABASE_MOCK='true' MONGO_CONNECTION_STRING='mongodb://test-string' FEATURE_FLAG_SDK_KEY='' vitest run",
    "test:watch": "CAMS_LOGIN_PROVIDER='mock' DATABASE_MOCK='true' MONGO_CONNECTION_STRING='mongodb://test-string' FEATURE_FLAG_SDK_KEY='' vitest watch",
    "typecheck": "npx tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@azure/communication-email": "1.1.0",
    "@azure/cosmos": "4.9.3",
    "@azure/functions": "4.16.1",
    "@azure/identity": "4.13.1",
    "@azure/keyvault-secrets": "4.11.2",
    "@azure/storage-blob": "12.33.0",
    "@azure/storage-queue": "12.31.0",
    "@launchdarkly/node-server-sdk": "9.11.3",
    "@okta/jwt-verifier": "4.0.2",
    "@okta/okta-sdk-nodejs": "8.1.0",
    "applicationinsights": "3.14.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "mongodb": "7.4.0",
    "mssql": "12.7.0",
    "name-match": "1.0.4",
    "natural": "8.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.0",
    "@types/express": "5.0.6",
    "@types/mssql": "12.3.0",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "azure-function-context-mock": "0.0.7",
    "dependency-cruiser": "17.4.3",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.9.4",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@azure/identity": "$@azure/identity"
  }
}
