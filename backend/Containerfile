# Multi-stage build for Node.js Express API
# Use official Node.js LTS image
FROM node:20-alpine AS builder

# Set working directory
WORKDIR /app

# Copy package files first for better Docker layer caching
COPY common/package*.json ./common/
COPY backend/package*.json ./backend/

# Install dependencies for common first
RUN cd common && npm ci

# Install backend dependencies  
RUN cd backend && npm ci

# Copy source code
COPY common/ ./common/
COPY backend/ ./backend/

# Build the TypeScript projects in correct order (common first, then backend core, then API)
RUN cd backend && npm run build-common && npm run build && npm run build:api

# Debug: Check what was built and look for Express files
RUN find /app/backend/dist -name "*.js" | grep -i express || echo "No Express files found"
RUN find /app/backend/dist -type f -name "*.js" | head -5

# Production stage
FROM node:20-alpine AS production

# Create a non-root user for security
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001

# Set working directory
WORKDIR /app

# Copy package files
COPY --from=builder /app/common/package*.json ./common/
COPY --from=builder /app/backend/package*.json ./backend/

# Copy built common package
COPY --from=builder --chown=nextjs:nodejs /app/common/dist ./common/dist
COPY --from=builder --chown=nextjs:nodejs /app/common/node_modules ./common/node_modules

# Copy built backend application
COPY --from=builder --chown=nextjs:nodejs /app/backend/dist ./backend/dist

# Copy dev dependencies node_modules from builder (needed for mock gateways)
COPY --from=builder --chown=nextjs:nodejs /app/backend/node_modules ./backend/node_modules

# Create a symlink to common package (since backend references it)
RUN cd backend && ln -sf ../common/dist ../common/package.json node_modules/

# Switch to non-root user
USER nextjs

# Set working directory to backend
WORKDIR /app/backend

# Expose the port the app runs on
EXPOSE 80

# Set environment variable for production
ENV NODE_ENV=production
ENV PORT=80

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD node -e "const http = require('http'); \
    const options = { hostname: 'localhost', port: process.env.PORT || 80, path: '/api/healthcheck', timeout: 5000 }; \
    const req = http.get(options, (res) => { \
        if (res.statusCode === 200) { console.log('Health check passed'); process.exit(0); } \
        else { console.log('Health check failed with status:', res.statusCode); process.exit(1); } \
    }); \
    req.on('error', (err) => { console.log('Health check error:', err.message); process.exit(1); }); \
    req.on('timeout', () => { console.log('Health check timeout'); req.destroy(); process.exit(1); });"

# Start the Express server
CMD ["node", "dist/backend/function-apps/express/app.js"]
