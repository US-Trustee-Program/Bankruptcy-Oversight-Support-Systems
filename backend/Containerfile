# Multi-stage build for Node.js Express API
# Use official Node.js LTS image
FROM node:20-alpine AS builder

# Set working directory
WORKDIR /app

# Copy package files first for better Docker layer caching
COPY common/package*.json ./common/
COPY backend/package*.json ./backend/

# Install dependencies for common first
RUN cd common && npm ci

# Install backend dependencies  
RUN cd backend && npm ci

# Copy source code
COPY common/ ./common/
COPY backend/ ./backend/

# Build the TypeScript projects in correct order (common first, then backend core, then API)
RUN cd backend && npm run build:api

# Production stage
FROM node:20-alpine AS production

# Create a non-root user for security
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001

# Set working directory
WORKDIR /app

# Mimic the pack.sh script structure - copy everything needed into the API directory
# This creates a self-contained deployment unit just like the pack script does

# Copy the API package.json and host.json
COPY --from=builder --chown=nextjs:nodejs /app/backend/function-apps/api/package.json ./backend/function-apps/api/package.json
COPY --from=builder --chown=nextjs:nodejs /app/backend/function-apps/api/host.json ./backend/function-apps/api/host.json

# Copy the built dist directory (contains all compiled JS files)
COPY --from=builder --chown=nextjs:nodejs /app/backend/function-apps/api/dist ./backend/function-apps/api/dist

# Copy backend node_modules to the API directory (just like pack.sh does with ../../node_modules/*)
# This makes all dependencies available in the same directory as the running application
COPY --from=builder --chown=nextjs:nodejs /app/backend/node_modules ./backend/function-apps/api/node_modules

# Debug: Verify the structure matches pack.sh expectations
RUN echo "=== Verifying pack.sh-like structure ===" && \
    ls -la /app/backend/function-apps/api/ && \
    echo "=== Checking for express in node_modules ===" && \
    ls -la /app/backend/function-apps/api/node_modules/ | grep express || echo "Express not found in node_modules" && \
    echo "=== Checking dist structure ===" && \
    find /app/backend/function-apps/api/dist -name "app.js" | head -3

# Switch to non-root user
USER nextjs

# Set working directory to backend
WORKDIR /app/backend/function-apps/api

# Expose the port the app runs on
EXPOSE 7071

# Set environment variable for production
ENV NODE_ENV=production
ENV PORT=7071

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD node -e "const http = require('http'); \
    const options = { hostname: 'localhost', port: process.env.PORT || 7071, path: '/api/healthcheck', timeout: 5000 }; \
    const req = http.get(options, (res) => { \
        if (res.statusCode === 200) { console.log('Health check passed'); process.exit(0); } \
        else { console.log('Health check failed with status:', res.statusCode); process.exit(1); } \
    }); \
    req.on('error', (err) => { console.log('Health check error:', err.message); process.exit(1); }); \
    req.on('timeout', () => { console.log('Health check timeout'); req.destroy(); process.exit(1); });"

# Start the Express server
CMD ["node", "dist/backend/function-apps/api/express/app.js"]
